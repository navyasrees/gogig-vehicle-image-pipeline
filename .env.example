# App
PORT=3000
NODE_ENV=development

# PostgreSQL
POSTGRES_USER=gogig
POSTGRES_PASSWORD=gogig_secret
POSTGRES_DB=gogig_db
DATABASE_URL="postgresql://gogig:gogig_secret@localhost:5432/gogig_db"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Worker
# Number of images the worker processes simultaneously.
# Tesseract.js (used for number plate OCR) is CPU-heavy and can consume
# ~150MB RAM per instance. At concurrency N, you may have N Tesseract
# processes running in parallel alongside N sets of Sharp operations.
# Start at 2 and profile before increasing — on a 2-core machine,
# going above 2 will likely cause contention and increase overall latency.
WORKER_CONCURRENCY=2
